---
import "../styles/global.css";

interface Props {
  title?: string;
  lang?: string;
}

const { title = "Nova VNDB — Join Us", lang = "en" } = Astro.props;
---

<!doctype html>
<html lang={lang} class="bg-bg text-ink font-sans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="bg-ink text-cream border-b-[3px]">
      <div class="max-w-[1100px] mx-auto px-8 flex items-center justify-between h-14 gap-8">
        <a
          href="/"
          class="text-[1.2rem] font-bold tracking-[0.04em] uppercase no-underline text-cream shrink-0 hover:text-[#d4a96a] transition-colors"
        >
          Nova VNDB
        </a>
        <nav class="flex">
          <a href="/" class="nav-link">Home</a>
          <a href="/positions/en" class="nav-link">Positions</a>
          <a href="/positions/ja" class="nav-link">募集要項</a>
        </nav>
      </div>
    </header>

    <main class="flex-1 max-w-[1100px] w-full mx-auto py-12 px-8">
      <slot />
    </main>

    <footer class="bg-surface border-t border-frame mt-auto">
      <div class="max-w-[1100px] mx-auto px-8 py-6">
        <p class="m-0 text-sm text-muted leading-relaxed">
          Nova VNDB: Carrying on the legacy of VNDB. Free, no ads, voluntary, reliable, open community.
        </p>
        <p class="m-0 mt-1 text-sm text-muted leading-relaxed" lang="ja">
          Nova VNDB: VNDBの精神を継ぐ。無料・広告なし・自発的・信頼性・オープンコミュニティ。
        </p>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav-link {
    color: var(--color-cream);
    text-decoration: none;
    padding: 0 1.1rem;
    height: 56px;
    display: flex;
    align-items: center;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
    border-left: 1px solid rgba(255, 255, 255, 0.12);
    transition: background-color 0.15s, color 0.15s;
  }

  .nav-link:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #d4a96a;
  }
</style>
